#!/usr/bin/env bash
# session-start hook for devkit
# Outputs the using-devkit skill content at session start

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
SKILL_FILE="${SCRIPT_DIR}/../skills/using-devkit/SKILL.md"

if [ -f "$SKILL_FILE" ]; then
  # Strip YAML frontmatter
  awk 'BEGIN{skip=0} /^---$/{skip++; next} skip<2{next} {print}' "$SKILL_FILE"
fi
